####################
# agent configuration
#####################
# https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# logging and observability
DEVOPS_AGENT_RUN_HISTORY_ENABLED=true
LANGFUSE_ENABLED=false
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-your-langfuse-public-key
# LANGFUSE_SECRET_KEY=sk-lf-your-langfuse-secret-key

# web based interface to agent
REDIS_URL=redis://127.0.0.1:6379/0
# DJANGO_SECRET_KEY=change-me
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Optional local Strands S3 session storage.
# DEVOPS_AGENT_SESSION_BACKEND=s3
# DEVOPS_AGENT_SESSION_S3_BUCKET=devops-agent-sessions
# DEVOPS_AGENT_SESSION_S3_ENDPOINT_URL=http://127.0.0.1:9000
# DEVOPS_AGENT_SESSION_S3_PREFIX=local/
# DEVOPS_AGENT_SESSION_S3_REGION=us-east-1
# Uses MINIO_ROOT_USER and MINIO_ROOT_PASSWORD below by default.

#######################
# ansible configuration
#######################
# MinIO object store
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Grafana configuration
GRAFANA_ADMIN_USER=change-me
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_HTTP_ADDR=0.0.0.0
GRAFANA_HTTP_PORT=3000
# GRAFANA_REPO_GPGKEY=change-me
# GRAFANA_REPO_URL_DEBIAN=change-me
# GRAFANA_REPO_URL_REDHAT=change-me
